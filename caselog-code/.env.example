# Supabase (optional - enables cloud sync across devices)
# The PWA works 100% offline using Dexie + local queue even if these are not set.
#
# Get your keys from Supabase Dashboard → Project Settings → API
#   - Use the "anon" / "public" key

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
